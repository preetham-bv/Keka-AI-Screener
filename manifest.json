{
  "manifest_version": 3,
  "name": "Keka ATS AI Reviewer",
  "version": "1.1.0",
  "description": "Multi-worker AI candidate screening pipeline with event-driven architecture",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [
    "storage",
    "alarms",
    "unlimitedStorage",
    "offscreen"
  ],
  "host_permissions": [
    "https://*.keka.com/*",
    "https://api.anthropic.com/*",
    "https://api.openai.com/*",
    "https://*.openai.azure.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
